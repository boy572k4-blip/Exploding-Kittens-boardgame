{
  "compilerOptions": {
    "outDir": "build",
    "target": "ESNext",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "allowJs": true,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": false,
    "types": [
      "mocha",
      "node"
    ],
    "lib": [
      "ES2023"
    ]
  },
  "include": [
    "src",
    "test"
  ]
}